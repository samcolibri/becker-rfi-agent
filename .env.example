# Hunter.io — email validation (Sam committed to this on 2026-04-16 call)
# Get key at hunter.io/api — free tier: 25 requests/mo, paid from $49/mo
HUNTER_API_KEY=your_hunter_api_key

# Server
PORT=3000
NODE_ENV=development

# Salesforce — Connected App credentials
SF_INSTANCE_URL=https://your-org.my.salesforce.com
SF_API_VERSION=v59.0
SF_CLIENT_ID=your_connected_app_client_id
SF_CLIENT_SECRET=your_connected_app_client_secret
SF_USERNAME=api_user@beckerprofessional.com
SF_PASSWORD=your_sf_password
SF_SECURITY_TOKEN=your_sf_security_token

# Salesforce Marketing Cloud
SFMC_AUTH_BASE_URL=https://YOUR_MID.auth.marketingcloudapis.com
SFMC_REST_BASE_URL=https://YOUR_MID.rest.marketingcloudapis.com
SFMC_CLIENT_ID=your_sfmc_client_id
SFMC_CLIENT_SECRET=your_sfmc_client_secret
SFMC_ACCOUNT_ID=your_sfmc_account_mid

# SFMC Journey Entry Event Keys (get from Journey Builder → Entry Source → API key)
SFMC_EVENT_CPA=CPA_Demo_Entry_v1
SFMC_EVENT_CMA=CMA_Demo_Entry_v1
SFMC_EVENT_CPE=CPE_Demo_Entry_v1
SFMC_EVENT_CIA=CIA_Demo_Entry_v1
SFMC_EVENT_EA=EA_Demo_Entry_v1
SFMC_EVENT_CFP=CFP_Demo_Entry_v1
SFMC_EVENT_B2B=B2B_Nurture_Entry_v1
SFMC_EVENT_GENERAL=General_Nurture_Entry_v1
